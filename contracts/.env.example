# Foundry auto-loads this file when you run `forge script` / `forge test` from
# the contracts/ directory. Copy it to `contracts/.env` and fill in:
#     cp contracts/.env.example contracts/.env
# `.env` is gitignored — NEVER commit real keys.

# Deployer wallet (funded with a little CELO for gas). Hex private key, 0x-prefixed.
PRIVATE_KEY=

# The scorer's ADDRESS (the address of the backend's SCORER_PRIVATE_KEY).
# Derive it from the key:  cast wallet address --private-key <SCORER_PRIVATE_KEY>
SCORER=

# Celo mainnet RPC.
RPC_URL=https://forno.celo.org

# ── optional (defaults shown) ───────────────────────────────────────────────
# Seconds per payout epoch.
EPOCH_LENGTH=86400
# Global max G$ wei payable per epoch (50 G$; G$ has 18 decimals).
EPOCH_CAP=50000000000000000000
# Contract owner (defaults to the deployer if left blank).
OWNER=
# G$ wei to seed the pool from the deployer at deploy time (0 = skip).
FUND_AMOUNT=0
# G$ token override (defaults to GoodDollar on Celo mainnet 0x62B8…9c7A).
# GD_TOKEN=0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A
