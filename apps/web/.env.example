# ── Wallet integration (Privy) ───────────────────────────────────────────────
# Create a Privy app at https://dashboard.privy.io and copy your App ID here.
# This is a public key — safe to expose in the browser bundle.
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Score-integrity backend (/settle) ───────────────────────────────────────
# The scorer signer key is the crown jewel. In production keep it in a KMS/HSM,
# plan rotation, and enforce the on-chain per-epoch payout cap. NEVER commit a
# real key. This example value is a well-known Anvil test key — local use only.
SCORER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944b6b0be62e1b6b5a3f6e1e9f6c8b6a1e

# GameRewards deployment the voucher is bound to (EIP-712 verifyingContract).
GAME_REWARDS_ADDRESS=0x0000000000000000000000000000000000000000

# Chain id the voucher is domain-separated against. 42220 = Celo mainnet (real G$).
CHAIN_ID=42220

# ── GoodDollar identity gate (/settle) ──────────────────────────────────────
# The server verifies the player is a GoodDollar-verified human on-chain before
# signing a voucher, and keys the daily cap on the returned root. REQUIRED in
# production; in dev a self-root fake is used if unset (no sybil resistance).
# GoodDollar Identity contract on Celo — CONFIRM against GoodDollar docs.
IDENTITY_CONTRACT=
# Celo RPC the identity read goes through (e.g. https://forno.celo.org).
RPC_URL=

# ── On-chain G$ relay (/settle) ─────────────────────────────────────────────
# A Celo wallet funded with ~0.1 CELO to pay gas for GameRewards.redeem() after
# every accepted settle. Can reuse the deployer key or be a separate key.
# Hex private key, 0x-prefixed. NEVER commit a real key.
RELAYER_PRIVATE_KEY=

# ── Session store (Upstash Redis) ───────────────────────────────────────────
# Optional in dev (falls back to in-memory). REQUIRED in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Tunables (optional; defaults shown) ─────────────────────────────────────
# Per-identity hard daily payout cap, in whole G$.
DAILY_CAP_GD=6
# Session lifetime in ms (time-box for a single run).
SESSION_TTL_MS=1800000
# Voucher redemption window in ms.
VOUCHER_TTL_MS=600000
# Minimum real ms one engine tick can represent (wall-clock plausibility gate).
MIN_MS_PER_TICK=50
